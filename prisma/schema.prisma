generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Bot {
  id                String   @id @default(uuid())
  nombre            String
  slug              String   @unique
  descripcion       String?
  tipoNegocio       String?
  estado            String   @default("activo")

  promptBase        String?
  tono              String?
  instrucciones     String?
  reglasNegocio     String?

  instanciaWhatsapp String?
  telefonoWhatsapp  String?
  apiKeyChatGPT     String?

  creadoEn          DateTime @default(now())
  actualizadoEn     DateTime @updatedAt

  catalogo          Catalogo[]
  clientes          BotClient[]
  conversaciones    BotConversation[]
  cotizaciones      BotQuotation[]
  campanias         BotCampaign[]
  contextosCampania ConversationCampaignContext[]

  @@map("bots")
}

model Catalogo {
  id                      String    @id @default(uuid())

  titulo                  String
  categoria               String
  descripcion             String?
  informacion             String?

  precio                  Float
  precioMinimo            Float?
  precioOferta            Float?
  stock                   Int       @default(0)

  imagen1                 String?
  imagen2                 String?
  imagen3                 String?
  video                   String?

  palabrasClave           String?
  reglasNegociacion       String?
  estado                  String    @default("activo")

  // === CAMPOS NUEVOS: productos inteligentes ===
  tipoProducto            String    @default("producto")          @map("tipo_producto")
  incluye                 String?
  permiteAdicionales      Boolean   @default(false)               @map("permite_adicionales")
  esCotizable             Boolean   @default(true)                @map("es_cotizable")
  orden                   Int       @default(0)
  cantidadBase            Int       @default(1)                   @map("cantidad_base")
  unidadAdicionalNombre   String?                                 @map("unidad_adicional_nombre")
  precioAdicional         Float     @default(0)                   @map("precio_adicional")
  precioMinimoAdicional   Float     @default(0)                   @map("precio_minimo_adicional")
  permiteCalculoAdicional Boolean   @default(false)               @map("permite_calculo_adicional")
  ciudadBase              String    @default("Higüey")            @map("ciudad_base")
  cargoFueraCiudad        Float     @default(0)                   @map("cargo_fuera_ciudad")
  aplicaCargoFueraCiudad  Boolean   @default(false)               @map("aplica_cargo_fuera_ciudad")
  instalacionIncluida     Boolean   @default(false)               @map("instalacion_incluida")
  reglasCalculo           Json      @default("{}")                @map("reglas_calculo")

  botId                   String?   @map("bot_id")

  creadoEn                DateTime  @default(now())
  actualizadoEn           DateTime  @updatedAt

  bot                     Bot?      @relation(fields: [botId], references: [id])

  @@index([botId], map: "idx_catalogo_bot_id")
  @@index([estado], map: "idx_catalogo_estado")
  @@map("catalogo")
}


model BotClient {
  telefono                  String    @id
  chatid                    String?
  nombre                    String?
  usuario_whatsapp          String?
  direccion                 String?
  ciudad                    String?
  sector                    String?
  referencia_direccion      String?
  interes_principal         String?
  producto_servicio_interes String?
  categoria_interes         String?
  presupuesto_estimado      Float?
  fecha_interes             DateTime? @db.Timestamptz(6)
  estado_cliente            String    @default("prospecto")
  etapa                     String    @default("inicio")
  fecha_reserva             DateTime? @db.Timestamptz(6)
  motivo_reserva            String?
  ultimo_mensaje            String?
  ultima_interaccion_at     DateTime? @default(now()) @db.Timestamptz(6)
  dias_sin_responder        Int?      @default(0)
  total_mensajes            Int       @default(1)
  resumen_conversacion      String?
  preferencias_cliente      String?
  datos_importantes         String?
  notas_internas            String?
  satisfaccion              String?   @default("no_evaluada")
  comentario_satisfaccion   String?
  ultima_compra_at          DateTime? @db.Timestamptz(6)
  productos_comprados       String?
  requiere_seguimiento      Boolean   @default(true)
  proximo_seguimiento_at    DateTime? @db.Timestamptz(6)
  motivo_seguimiento        String?
  cantidad_seguimientos     Int       @default(0)
  ultimo_seguimiento_at     DateTime? @db.Timestamptz(6)
  bot_pausado               Boolean   @default(false)
  humano_tomo_control       Boolean   @default(false)
  metadata                  Json      @default("{}")
  creado_en                 DateTime  @default(now()) @db.Timestamptz(6)
  actualizado_en            DateTime  @default(now()) @db.Timestamptz(6)

  botId                     String?   @map("bot_id")

  bot                       Bot?      @relation(fields: [botId], references: [id])

  @@index([botId], map: "idx_bot_clients_bot_id")
  @@index([estado_cliente], map: "idx_bot_clients_estado_cliente")
  @@index([etapa], map: "idx_bot_clients_etapa")
  @@index([producto_servicio_interes], map: "idx_bot_clients_interes")
  @@index([proximo_seguimiento_at], map: "idx_bot_clients_proximo_seguimiento")
  @@index([requiere_seguimiento], map: "idx_bot_clients_requiere_seguimiento")
  @@index([ultima_interaccion_at(sort: Desc)], map: "idx_bot_clients_ultima_interaccion")

  @@map("bot_clients")
}

model BotConversation {
  id         Int      @id @default(autoincrement())
  session_id String
  message    Json
  created_at DateTime @default(now()) @db.Timestamptz(6)

  botId      String?  @map("bot_id")

  bot        Bot?     @relation(fields: [botId], references: [id])
  @@index([botId], map: "idx_bot_conversations_bot_id")
  @@index([created_at(sort: Desc)], map: "idx_bot_conversations_created_at")
  @@index([session_id], map: "idx_bot_conversations_session_id")

  @@map("bot_conversations")
}

model BotQuotation {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  numero_cotizacion   String    @unique
  telefono_cliente    String
  nombre_cliente      String?
  direccion_cliente   String?
  ciudad              String?
  sector              String?
  titulo              String    @default("Cotización de servicios")
  descripcion_general String?
  productos           Json      @default("[]")
  subtotal            Float     @default(0)
  descuento           Float     @default(0)
  total               Float     @default(0)
  moneda              String    @default("DOP")
  estado              String    @default("pendiente")
  pdf_url             String?
  observaciones       String?
  condiciones         String?
  valida_hasta        DateTime? @db.Timestamptz(6)
  creada_por          String?   @default("bot")
  creado_en           DateTime  @default(now()) @db.Timestamptz(6)
  actualizado_en      DateTime  @default(now()) @db.Timestamptz(6)

  botId               String?   @map("bot_id")

  bot                 Bot?      @relation(fields: [botId], references: [id])

  @@index([botId], map: "idx_bot_quotations_bot_id")
  @@index([creado_en(sort: Desc)], map: "idx_bot_quotations_creado_en")
  @@index([estado], map: "idx_bot_quotations_estado")
  @@index([telefono_cliente], map: "idx_bot_quotations_telefono_cliente")

  @@map("bot_quotations")
}

model BotOrder {
  id                String    @id @default(uuid())
  telefonoCliente   String    @map("telefono_cliente")
  nombreCliente     String?   @map("nombre_cliente")
  productoServicio  String?   @map("producto_servicio")
  tipoServicio      String?   @default("otro") @map("tipo_servicio")
  direccion         String?
  fechaDeseada      String?   @map("fecha_deseada")
  estadoPedido      String?   @default("pendiente") @map("estado_pedido")
  resumenPedido     String?   @map("resumen_pedido")
  creadoEn          DateTime? @default(now()) @map("creado_en")
  actualizadoEn     DateTime? @updatedAt @map("actualizado_en")

  @@index([estadoPedido], map: "idx_bot_orders_estado_pedido")
  @@index([telefonoCliente], map: "idx_bot_orders_telefono_cliente")
  @@map("bot_orders")
}

model BotCampaign {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bot_id           String
  campaign_code    String
  campaign_name    String
  keywords         Json     @default("[]")
  trigger_phrases  Json     @default("[]")
  initial_message  String?
  campaign_context String?
  media_urls       Json     @default("[]")
  active           Boolean  @default(true)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)

  bot              Bot      @relation(fields: [bot_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  contextos        ConversationCampaignContext[]

  @@unique([bot_id, campaign_code], map: "uq_campaign_bot_code")
  @@index([bot_id], map: "idx_bot_campaigns_bot_id")
  @@index([active], map: "idx_bot_campaigns_active")
  @@map("bot_campaigns")
}

model ConversationCampaignContext {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bot_id                  String
  conversation_id         String
  customer_id             String?
  campaign_id             String?   @db.Uuid
  campaign_code           String?
  campaign_name           String?
  matched_keyword         String?
  matched_trigger_phrase  String?
  customer_message        String?
  detection_confidence    Float     @default(0)
  source_channel          String    @default("whatsapp")
  status                  String    @default("detectada")
  initial_message_sent_at DateTime? @db.Timestamptz(6)
  last_response_at        DateTime? @db.Timestamptz(6)
  created_at              DateTime  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime  @default(now()) @db.Timestamptz(6)

  bot                     Bot       @relation(fields: [bot_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  campaign                BotCampaign? @relation(fields: [campaign_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  @@index([bot_id], map: "idx_conv_campaign_bot_id")
  @@index([conversation_id], map: "idx_conv_campaign_conversation_id")
  @@index([campaign_id], map: "idx_conv_campaign_campaign_id")
  @@index([status], map: "idx_conv_campaign_status")
  @@index([created_at(sort: Desc)], map: "idx_conv_campaign_created_at")
  @@map("conversation_campaign_context")
}
