# ============================================
# Configuración de Base de Datos (PostgreSQL)
# ============================================
DB_USER=fulltech_bot
DB_PASSWORD=your_db_password_here
DB_NAME=fulltech_bot

# ============================================
# Configuración del Backend
# ============================================
PORT=3000
NODE_ENV=production

# ============================================
# Configuración de Storage (Cloudflare R2)
# ============================================
STORAGE_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY_ID=your_access_key_id
STORAGE_SECRET_ACCESS_KEY=your_secret_access_key
STORAGE_BUCKET=fulltechbot
STORAGE_PUBLIC_URL="https://your-account-id.r2.cloudflarestorage.com/fulltechbot"
